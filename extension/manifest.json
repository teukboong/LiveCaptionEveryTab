{
  "manifest_version": 3,
  "name": "Live Caption Every Tab",
  "version": "0.1.0",
  "description": "Realtime captions + local-LLM translation for any browser tab (YouTube/Twitch/X/…). Fully local, target language selectable.",
  "key": "",
  "permissions": ["tabCapture", "offscreen", "activeTab", "scripting", "storage", "nativeMessaging"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Live Caption Every Tab" },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["protocol.js", "pcm.js", "page-seed.js", "caption-overlay.js", "content.js", "delay.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pcm-worklet.js"],
      "matches": ["*://*/*"]
    }
  ]
}
