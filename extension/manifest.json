{
  "manifest_version": 3,
  "name": "Live Caption (KR)",
  "version": "0.1.0",
  "description": "Realtime foreign→Korean captions for any site (YouTube/Twitch/X/…) via a local Gemma-4 bridge.",
  "key": "",
  "permissions": ["tabCapture", "offscreen", "activeTab", "storage", "nativeMessaging"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Live Caption (KR)" },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["protocol.js", "pcm.js", "content.js", "delay.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pcm-worklet.js"],
      "matches": ["*://*/*"]
    }
  ]
}
