# CUDA backend config for the live-caption bridge. Copy to ~/.lcc-cuda.env and edit, then run_bridge_cuda.sh
# sources it. Every value has a sensible default in backend_cuda.py — only set what you need to change.

# --- Translation (llama.cpp llama-server, OpenAI chat.completions) ------------------------------------
LCC_CUDA_CHAT_URL=http://127.0.0.1:8080/v1/chat/completions
# llama.cpp ignores the model name; vLLM needs the exact served name.
LCC_CUDA_CHAT_MODEL=local
# Keep 0: the bridge sends chat_template_kwargs:{enable_thinking:false} (needs llama-server --jinja). Set to
# 1 only if your server/template has no thinking channel and rejects the kwarg.
LCC_CUDA_ENABLE_THINKING=0

# --- ASR (granite=영어 / qwen3=다국어, 같은 모델을 CUDA에서) ------------------------------------------
# 전사는 Mac과 동일한 granite-speech-4.1 / Qwen3-ASR. 8GB VRAM에서는 둘을 동시에 상주시키지 말고
# switch_asr_gguf.sh로 팝업 엔진 전환 때 선택된 GGUF ASR 서버만 :8000에 띄운다. whisper 안 씀.
LCC_CUDA_ASR_URL=http://127.0.0.1:8000/v1/audio/transcriptions
LCC_CUDA_ASR_SWITCH_CMD=$HOME/live-caption/projects/live-caption/bridge/cuda/switch_asr_gguf.sh
LCC_CUDA_ASR_LLAMA_BIN=$HOME/runtime/llama.cpp-gemma4-mtp/build-cuda126/bin/llama-server
LCC_CUDA_ASR_PORT=8000
LCC_CUDA_ASR_NGL=all
LCC_CUDA_ASR_GRANITE_MODEL=local
LCC_CUDA_ASR_QWEN3_MODEL=local
LCC_CUDA_ASR_GRANITE_GGUF=$HOME/models/live-caption-cuda8/asr-gguf-q6/granite/granite-speech-4.1-2b-Q6_K.gguf
LCC_CUDA_ASR_GRANITE_MMPROJ=$HOME/models/live-caption-cuda8/asr-gguf-q6/granite/mmproj-model-f16.gguf
LCC_CUDA_ASR_QWEN3_GGUF=$HOME/models/live-caption-cuda8/asr-gguf-q6/qwen3/Qwen3-ASR-1.7B-Q6_K.gguf
LCC_CUDA_ASR_QWEN3_MMPROJ=$HOME/models/live-caption-cuda8/asr-gguf-q6/qwen3/mmproj-Qwen3-ASR-1.7B-bf16.gguf
# If local converted Q6 files are not present, use llama.cpp's Hugging Face loader instead.
# LCC_CUDA_ASR_GRANITE_HF=ibm-granite/granite-speech-4.1-2b-GGUF:Q8_0
# LCC_CUDA_ASR_QWEN3_HF=mradermacher/Qwen3-ASR-1.7B-GGUF:Q6_K
# 한 엔진을 다른 서버에 따로 꽂고 싶을 때만(예: qwen3를 별도 vLLM 포트로):
#   LCC_CUDA_ASR_GRANITE_URL=http://127.0.0.1:8000/v1/audio/transcriptions
#   LCC_CUDA_ASR_QWEN3_URL=http://127.0.0.1:8001/v1/audio/transcriptions
# model 필드 override(서버가 다른 이름을 기대할 때). 기본은 엔진 이름(granite/qwen3)을 그대로 보냄:
#   LCC_CUDA_ASR_GRANITE_MODEL=granite
#   LCC_CUDA_ASR_QWEN3_MODEL=qwen3
# asr_server.py가 로드할 실제 repo(필요 시):
#   LCC_CUDA_ASR_GRANITE_REPO=ibm-granite/granite-speech-4.1-2b
#   LCC_CUDA_ASR_QWEN3_REPO=Qwen/Qwen3-ASR-1.7B

# --- Misc ----------------------------------------------------------------------------------------------
# LCC_CUDA_API_KEY=          # Bearer token if your server requires one (vLLM --api-key)
# LCC_CUDA_TIMEOUT=60        # per-request HTTP timeout (seconds)
# LCC_CUDA_TEMPERATURE=0.0   # translation sampling temperature

# --- Bridge serve scripts (used by serve_llama.sh / serve_whisper.sh) ---------------------------------
# LCC_LLAMA_GGUF=$HOME/models/gemma-4-26b-a4b-it-Q4_K_M.gguf
# LCC_WHISPER_MODEL=large-v3        # medium / small are lighter
# LCC_WHISPER_COMPUTE=float16       # int8_float16 to save VRAM
