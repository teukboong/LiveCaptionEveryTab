# Live Caption Every Tab — optional configuration. Copy to `.env` and edit, or `export` these before
# launching the bridge. The launcher currently sources ~/.lcc-policy.env; a repo-local `.env` loader
# is wired in the packaging step. Every value below has a smart default — you can run with none of it.

# ─────────────────────────────────────────────────────────────────────────────────────────────────
# Translation-model tier — sized to AVAILABLE memory (idle VRAM), not total RAM.
# Leave everything unset for auto-detect (recommended). To PIN a tier (reproducible across launches):
#   full = gemma-4-26B-A4B (best quality, ~18GB resident)   ← idle machines with ≥~22GB free
#   mid  = gemma-4-E4B QAT (balanced,    ~8GB resident)      ← ~12GB free  (16GB-class machines)
#   lite = gemma-4-E2B     (minimal,     ~5GB resident)      ← ~8GB free   (also drops ASR to 0.6B)
# ─────────────────────────────────────────────────────────────────────────────────────────────────
# LCC_LM_TIER=mid

# Hard override: use this exact translator repo/id regardless of tier (power users).
# LCC_LM_MODEL=mlx-community/gemma-4-26b-a4b-it-6bit

# Override the model each tier maps to (MLX repo ids / CUDA llama.cpp GGUF labels):
# LCC_LM_MID_MLX=mlx-community/gemma-4-E4B-it-qat-assistant-6bit
# LCC_LM_LITE_MLX=mlx-community/gemma-4-e2b-it-4bit
# LCC_LM_FULL_CUDA=gemma-4-26b-a4b-it-qat-q4_0
# LCC_LM_MID_CUDA=gemma-4-e4b-it-qat-q4_0
# LCC_LM_LITE_CUDA=gemma-4-e2b-it-qat-q4_0

# Tune the auto-detect footprint model (GB). NEED_* = resident footprint per tier; HEADROOM = OS/browser
# slack kept free so a growing browser won't push the model into swap. Lower NEED/HEADROOM = more aggressive.
# LCC_LM_NEED_FULL=18
# LCC_LM_NEED_MID=8
# LCC_LM_NEED_LITE=5
# LCC_LM_HEADROOM_GB=4

# ─────────────────────────────────────────────────────────────────────────────────────────────────
# ASR (transcription)
# ─────────────────────────────────────────────────────────────────────────────────────────────────
# LCC_ASR_ENGINE=granite                # granite (EN-strong) | qwen3 (multilingual) | parakeet (EN, CPU)
# LCC_GRANITE_MODEL=ibm-granite/granite-speech-4.1-2b
# LCC_QWEN3_MODEL=Qwen/Qwen3-ASR-1.7B   # auto -> 0.6B on the lite tier

# ─────────────────────────────────────────────────────────────────────────────────────────────────
# Compute backend / runtime
# ─────────────────────────────────────────────────────────────────────────────────────────────────
# LCC_BACKEND=mlx                       # mlx (Apple Silicon, default) | cuda (Windows+NVIDIA via WSL2)
# LCC_TX_PROFILE=quality                # quality (default) | fast (lower latency, compact prompt)
# LCC_LATENCY_MODE=aggressive           # stable | balanced | aggressive
# LCC_PYTHON=/path/to/venv/bin/python   # interpreter the launcher uses

# ─────────────────────────────────────────────────────────────────────────────────────────────────
# Local WebSocket bridge (loopback only by default)
# ─────────────────────────────────────────────────────────────────────────────────────────────────
# LCC_HOST=127.0.0.1
# LCC_PORT=8765
# LCC_WS_TOKEN=lcc-local-extension-v1   # must match extension/protocol.js if changed
